library(sf)
library(sfnetworks)
library(ggplot2)
# Start out by reading in the data
R5hydro<-st_read("S:/FP/Reg5/Harris, Jeremy/Hydro/R5_Stream_Layer.shp")
R5hydro<-st_transform(R5hydro,crs=2286)
R5hydro<-st_zm(R5hydro)
R5hydro<-st_cast(R5hydro,"LINESTRING",warn = F)
R5hydro$STRM_NAME[R5hydro$STRM_NAME=="Rock Creek" & is.na(R5hydro$STRM_NAME)==F]<-paste0("Rock Creek ",LETTERS[1:11])
# Let's grab the surveys, and filter down to steelhead
surveys0<-read.csv("C:/Users/harj3477/Jeremy Documents/R materials/All_tws_surveys_improved.csv")
surveys0$Year<-as.integer(format(as.Date(surveys0$survey_date),format="%Y"))
surveys0$Day<-as.integer(format(as.Date(surveys0$survey_date),format="%j"))
surveys0$Mon<-as.integer(format(as.Date(surveys0$survey_date),format="%m"))
surveys0<-surveys0[which(is.na(surveys0$no_survey_reason)),]
surveys0<-surveys0[-which(surveys0$water_visibility=="Poor"),]
surveys<-subset(surveys0,Day>=244 | Day<=31)
surveys<-subset(surveys,Year>=2012)
surveys<-subset(surveys,management_basin=="Elochoman, Skamokawa")
surveys<-surveys[,c(1:2,5,7:8,12,17:18,20:28,45:46,48:50,57,61,62,64:66)]
names(surveys)[names(surveys)=="return_yr"]<-"Runyear"
names(surveys)[names(surveys)=="stream_name"]<-"Stream"
names(surveys)[names(surveys)=="water_visibility"]<-"Vis"
names(surveys)[names(surveys)=="survey_method"]<-"Method"
names(surveys)[names(surveys)=="stream_reach_code"]<-"Str_code"
names(surveys)[names(surveys)=="management_basin"]<-"Pop"
names(surveys)[names(surveys)=="subpopulation"]<-"Subpop"
names(surveys)[names(surveys)=="cm_survey_count_type"]<-"Cm_count"
names(surveys)[names(surveys)=="co_survey_count_type"]<-"Co_count"
names(surveys)[names(surveys)=="co_redd_survey_type"]<-"Co_redds"
table(surveys$Co_count,useNA = "a")
table(surveys$Co_redds,useNA = "a")
# we will use coho surveys to help establish a spatial frame
coho.surveys<-surveys[is.na(surveys$Co_count)==F & surveys$Co_count!="No Survey" |
is.na(surveys$Co_redds)==F & surveys$Co_redds!="No Redd Count" ,]
coho.pres.surveys<-coho.surveys[sort(unique(c(which(coho.surveys$co_total_redds>0),
which(coho.surveys$co_lives>0),
which(coho.surveys$co_deads>0)))),]
chum.surveys0<-surveys[which(surveys$Cm_count=="Full Survey"),]
chum.surveys0<-chum.surveys0[is.na(chum.surveys0$lower_lat)==F,]
coho.pres.surveys<-coho.pres.surveys[is.na(coho.pres.surveys$lower_lat)==F,]
##############################################################################################
Eloch.path<-"C:/Users/harj3477/Jeremy Documents/R materials/Elochoman_River_Chum/"
# Preliminary setup while we construct the survey lines
Eloch.root0<-st_transform(PointSetup(point = c(-123.563,46.257),crs ="wgs84" ),crs=2286)
Eloch.basin<-ExtractBasin(shape = R5hydro,root = Eloch.root0,attach.data = F,
basins = c("Elochoman River","Jim Crow Creek","Skamokawa Creek"))
Eloch.basin<-ExtractBasin(shape = R5hydro,root = Eloch.root0,attach.data = F,
basins = c("Elochoman River","Jim Crow Creek","Skamokawa Creek"))
Eloch.basin2<-RootNetwork(Eloch.basin,root = Eloch.root0)
chum.surveys<-MakeSurveyTracks(shape = Eloch.basin, surveys = chum.surveys0,
maxdist = 200, surveys.crs = "wgs84",
survey.coords = c("upper_lon","upper_lat","lower_lon","lower_lat"))
# Preliminary setup while we construct the survey lines
Eloch.root0<-st_transform(PointSetup(point = c(-123.563,46.257),crs ="wgs84" ),crs=2286)
Eloch.basin<-ExtractBasin(shape = R5hydro,root = Eloch.root0,attach.data = F,
basins = c("Elochoman River","Jim Crow Creek","Skamokawa Creek"))
