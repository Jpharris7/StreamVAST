# Try spawners with a delta
LG.vast<-ConstructStreamVAST(countdata = "C:/Users/harj3477/Jeremy Documents/R materials/Lower_Gorge_chum/Lower_Gorge_chum_data.csv",
reachdata = "C:/Users/harj3477/Jeremy Documents/R materials/Lower_Gorge_chum/Lower_Gorge_chum_reaches.shp",
surveydata = "C:/Users/harj3477/Jeremy Documents/R materials/Lower_Gorge_chum/Lower_Gorge_chum_surveys.shp",
countname = "Spawners")
############################################
# Try deads
LG.vast2<-ConstructStreamVAST(countdata = "C:/Users/harj3477/Jeremy Documents/R materials/Lower_Gorge_chum/Lower_Gorge_chum_data.csv",
reachdata = "C:/Users/harj3477/Jeremy Documents/R materials/Lower_Gorge_chum/Lower_Gorge_chum_reaches.shp",
surveydata = "C:/Users/harj3477/Jeremy Documents/R materials/Lower_Gorge_chum/Lower_Gorge_chum_surveys.shp",
countname = "Deads")
LG.vast2<-SetTemporalFrame(streamvast=LG.vast2,Time = "Year",startdate = "2012-9-15",enddate = "2024-01-15",
season=c(9,15,1,15),padyear = T,padhabitat=T)
vastdata<-LG.vast2$vastdata
runyear.vec<-sort(unique(vastdata$Runyear))
reach.vec<-sort(unique(vastdata$Reach))
out.vec<-rep(NA,nrow(vastdata))
for(y in 1:length(runyear.vec)){
for(r in 1:length(reach.vec)){
index<-which(vastdata$Runyear==runyear.vec[y] & vastdata$Reach==reach.vec[r])
index.dat<-vastdata[index,]
dayorder<-order(index.dat$Statday)
index.dat2<-index.dat[dayorder,]
survivals<-rep(NA,nrow(index.dat2))
fixed.count<-rep(NA,nrow(index.dat2))
fixed.count2<-rep(NA,nrow(index.dat2))
for(d in 1:nrow(index.dat2)){
count<-index.dat2$Deads[d]
unobserved<-count*.45
if(d==1){
survivals[d]<-0
}else{
day.diff<-index.dat2$Statday[d]-index.dat2$Statday[d-1]
survivals[d]<-(survivals[d-1]+index.dat2$Deads[d-1])*(1-pexp(q=day.diff,rate = .105))
}
fixed.count[d]<-count+unobserved+survivals[d]
}
fixed.count2[dayorder]<-fixed.count
out.vec[index]<-fixed.count2
}
}
LG.vast2$vastdata$Deads2<-round(out.vec)
old.deads<-LG.vast2$vastdata$Deads
LG.vast2$vastdata$Deads<-round(out.vec)
### Calculate spawners from previous 30 days
LG.vast2$countdata$Date<-as.Date(paste0(LG.vast2$countdata$Year,"-",LG.vast2$countdata$Day),format="%Y-%j")
out.vec<-rep(0,nrow(LG.vast2$vastdata))
for(i in 1:nrow(LG.vast2$vastdata)){
year<-LG.vast2$vastdata$Runyear[i]
reach<-LG.vast2$vastdata$Reach[i]
day<-as.Date(LG.vast2$vastdata$Date[i])
dayrange<-seq(from=day-30,to=day-1,by=1)
previous.dat<-subset(LG.vast2$countdata,Reach==reach & Date%in%dayrange)
if(nrow(previous.dat)>0){out.vec[i]<-sum(previous.dat$Spawner)}
}
LG.vast2$vastdata$Spawners<-out.vec
#still not much of a relationship
plot(Deads~Spawners,data=LG.vast2$vastdata)
plot(Deads~Spawners,data=LG.vast2$countdata)
fit<-tinyVAST( data = LG.vast2$vastdata,
formula = Deads ~ 1 + s(Statday) + offset(log(Effort)),
spatial_graph = LG.vast2$vastnetwork,
space_columns = c("Lon","Lat"),
variable_column = "Species",
time_column = "Runyear",
distribution_column = "Dist",
sem = "",
dsem = "Deads -> Deads, 1, rho",
delta_options = list(delta_formula = ~0 + s(Statday) + s(Spawners,bs="ps",m=1)+ offset(log(Effort)),
delta_sem = "",
delta_dsem = "Deads -> Deads,1,phi"),
family=delta_gamma(type = "poisson"),
#family=poisson(),
control = tinyVASTcontrol(getJointPrecision = TRUE))
fit$sdrep$pdHess
fit$sdrep
fit$deviance_explained
AIC(fit)
LG.vast2$vastmodel<-fit
# Make the prediction data
timevec<-LG.vast2$timetable$Time
reachvec<-as.data.frame(LG.vast2$reachdata)[,LG.vast2$reachname]
nreach<-length(reachvec)
# If an auc estimate is desired, need to make sure we have enough data points within each year
# if the time frame is month, week, etc, that should happen automatrically, so can use the simpler method
date.dat<-data.frame(Time=vector(),Runyear=vector(),Date=as.Date(NULL))
for(i in 1:nrow(LG.vast2$timetable)){
date.dat<-rbind(date.dat,data.frame(Time=LG.vast2$timetable$Time[i],
Runyear=LG.vast2$timetable$Runyear[i],
Date=seq(from=LG.vast2$timetable$Start[i],
to=LG.vast2$timetable$End[i],by=15)))
}
# Finish filling out the newdata object
newdata<-data.frame(Time=rep(date.dat$Time,each=nreach),
Runyear=rep(date.dat$Runyear,each=nreach),
Date=rep(date.dat$Date,each=nreach))
newdata$Year<-as.integer(format(newdata$Date,"%Y"))
newdata$Month<-as.integer(format(newdata$Date,"%m"))
newdata$Day<-as.integer(format(newdata$Date,"%d"))
newdata$Statday<-as.integer(1+newdata$Date-LG.vast2$timetable$Start[match(newdata$Time,LG.vast2$timetable$Time)])
newdata$Reach<-rep_len(reachvec,length.out=nrow(newdata))
speciesname<-LG.vast2$vastmodel$call[["variable_column"]]
speciesval<-unique(LG.vast2$vastdata[,speciesname])
newdata$variable_column<-speciesval
names(newdata)[ncol(newdata)]<-speciesname
distname<-LG.vast2$vastmodel$call[["distribution_column"]]
distval<-unique(LG.vast2$vastdata[,distname])
newdata$distribution_column<-distval
names(newdata)[ncol(newdata)]<-distname
reachmatch<-match(newdata$Reach,as.data.frame(LG.vast2$reachdata)[,LG.vast2$reachname])
newdata$Habitat<-LG.vast2$reachdata$habitat[reachmatch]
newdata$Length<-LG.vast2$reachdata$Length[reachmatch]
newdata$Effort<-newdata$Length
newdata$Lon<-LG.vast2$reachdata$CenterLon[reachmatch]
newdata$Lat<-LG.vast2$reachdata$CenterLat[reachmatch]
names(newdata)[names(newdata)=="Reach"]<-LG.vast2$reachname
# Calculate spawners for the preds
out.vec<-rep(0,nrow(newdata))
for(i in 1:nrow(newdata)){
year<-newdata$Runyear[i]
reach<-newdata$Reach[i]
day<-as.Date(newdata$Date[i])
dayrange<-seq(from=day-30,to=day-1,by=1)
previous.dat<-subset(LG.vast2$countdata,Reach==reach & Date%in%dayrange)
if(nrow(previous.dat)>0){out.vec[i]<-sum(previous.dat$Spawner)}
}
newdata$Spawners<-out.vec
LG.vast2<-VASTpreds(streamvast = LG.vast2,makeauc = T,nsims = 100,bias.correct = F,newdata = newdata)
LG.vast2$stats
ncol(LG.vast2$sims$predsims)
Dharmaplot(LG.vast2,span=.15)
plotPredictionMap(streamvast = LG.vast2,mapvar = "pred_Density",legendname = "Carcass Density")
plotPredictionMap(streamvast = LG.vast2,mapvar = "pred_Density_SE2")
dat.label2<-data.frame(x=0,y=max(LG.vast2$eval$Density),
lab=paste0("r = ",round(LG.vast2$stats$rhoS,2),
"\nRMSE = ",round(LG.vast2$stats$RMSE,2)))
ggplot(data=LG.vast2$eval)+
