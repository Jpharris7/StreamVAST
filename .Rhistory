control = tinyVASTcontrol(getJointPrecision = TRUE))
fit$sdrep$pdHess
fit$sdrep
fit$deviance_explained
AIC(fit)
LG.vast$vastmodel<-fit
LG.vast<-VASTpreds(streamvast = LG.vast,makeauc = T,nsims = 100,bias.correct = F)
LG.vast$stats
ncol(LG.vast$sims$predsims)
plot(GC.vast$aucdata$auctotals$pred_AUC/SOS.escape$Escapement,typ="l")
plot(x=2012:2023,y=GC.vast$aucdata$auctotals$pred_AUC/SOS.escape$Escapement,typ="l")
abline(h=mean(GC.vast$aucdata$auctotals$pred_AUC/SOS.escape$Escapement),lty=3)
plotEscapement(streamvast = GC.vast,obs.escape = SOS.escape,ribbons = 50,median = T,
title="Live Spawner Escapement")
plotEscapement(streamvast = GC.vast.alt,obs.escape = SOS.escape,ribbons = 50,median = T,
title="Live Spawner Escapement")
plotEscapement(streamvast = GC.vast.alt,obs.escape = SOS.escape,ribbons = 45,median = T,
title="Live Spawner Escapement")
